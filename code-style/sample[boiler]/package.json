{
  "name": "penning-meester",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "lint": "eslint src --ext .ts --fix",
    "format": "prettier --write  \"{src,apps,libs,test}/**/*.{ts,js,json,md,jsx,tsx}\"",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky",
    "migration:run": "pnpx ts-node --transpile-only -r tsconfig-paths/register node_modules/typeorm/cli.js migration:run -d ./src/common/database/dbConfig.ts",
    "migration:generate": "cross-env pnpx ts-node --transpile-only -r tsconfig-paths/register node_modules/typeorm/cli.js migration:generate ./src/common/database/migrations/migration -d ./src/common/database/dbConfig.ts",
    "migration:create": "cross-env pnpx ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:create ./src/common/database/migrations/%npm_config_name% -d ./src/common/database/dbConfig.ts",
    "migration:revert": "cross-env pnpx ts-node --transpile-only -r tsconfig-paths/register node_modules/typeorm/cli.js migration:revert -d ./src/common/database/dbConfig.ts",
    "migration:show": "pnpx ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:show -d ./src/common/database/dbConfig.ts",
    "typeorm": "pnpx ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js"
  },
  "dependencies": {
    "@automapper/classes": "^8.8.1",
    "@automapper/core": "^8.8.1",
    "@automapper/nestjs": "^8.8.1",
    "@nestjs/common": "^11.0.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.16",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.16",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.2",
    "chalk": "4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-basic-auth": "^1.2.1",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "multer": "2.0.1",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^11.0.13",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.3.1",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "@automapper/classes": {
      "reflect-metadata": "^0.2.2"
    },
    "@automapper/nestjs": {
      "@nestjs/common": "^11.0.2",
      "@nestjs/core": "^11.0.2"
    }
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}